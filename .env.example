# Скопируй в .env и впиши свой ключ. .env не коммить в git!

# OpenAI-совместимый эндпоинт. По умолчанию OpenRouter (доступен из РФ).
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=впиши_сюда_свой_ключ
LLM_MODEL=openai/gpt-4o-mini

# Origin твоего фронта (GitHub Pages). Несколько — через запятую.
# Для локальной отладки можно оставить *
ALLOWED_ORIGINS=https://ТВОЙ_ЛОГИН.github.io
